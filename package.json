{
  "name": "portfolio-rohan",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||'';if(!ua.includes('pnpm')){console.error('Use pnpm instead of npm/yarn');process.exit(1)}\"",
    "build": "pnpm --filter @workspace/portfolio run build",
    "dev": "pnpm --filter @workspace/portfolio run dev",
    "typecheck": "pnpm --filter @workspace/portfolio run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
